{
  "app-id": "io.github.george0884.SysMonitorPro",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sysmonitor",
  "finish-args": [
    "--socket=x11",
    "--socket=wayland",
    "--share=ipc",
    "--share=network",
    "--device=dri",
    "--filesystem=host"
  ],
  "modules": [
    {
      "name": "sysmonitorpro",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app psutil",
        "install -D sysmonitorpro.py /app/bin/sysmonitor",
        "chmod +x /app/bin/sysmonitor"
      ],
      "sources": [
        {
          "type": "file",
          "path": "sysmonitorpro.py"
        }
      ]
    }
  ]
}
